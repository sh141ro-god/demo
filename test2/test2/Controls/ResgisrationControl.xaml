<UserControl
    x:Class="test2.Controls.ResgisrationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:test2.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Vertical">

            <TextBox
                x:Name="LoginText"
                MinWidth="75"
                MaxWidth="75"
                Margin="2"
                Padding="5" />
            <TextBox
                x:Name="PasswordText"
                MinWidth="75"
                MaxWidth="75"
                Margin="2"
                Padding="5" />
            <Button
                Name="LoginButton"
                MinWidth="50"
                Margin="2"
                Padding="5"
                Content="Войти" />
            <Button
                Name="GustButton"
                MinWidth="50"
                Margin="2"
                Padding="5" />
        </StackPanel>

    </Grid>
</UserControl>
