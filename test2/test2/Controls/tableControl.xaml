<UserControl
    x:Class="test2.Controls.tableControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:test2.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  поиск  -->
            <RowDefinition Height="*" />
            <!--  список: заполняет остаток и скроллится  -->
        </Grid.RowDefinitions>

        <TextBox
            Grid.Row="0"
            Width="200"
            MinHeight="15"
            Margin="5"
            HorizontalAlignment="Center"
            TextChanged="Search" />

        <ListBox
            x:Name="MainList"
            Grid.Row="1"
            Margin="5"
            HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="5"
                        Padding="5"
                        BorderBrush="#DDD"
                        BorderThickness="1"
                        CornerRadius="5">
                        <StackPanel>
                            <TextBox Margin="2" Text="{Binding Name}" />
                            <TextBox Margin="2" Text="{Binding Description}" />
                            <ComboBox
                                Margin="2"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                SelectedValue="{Binding IdCategory}"
                                SelectedValuePath="Id" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
